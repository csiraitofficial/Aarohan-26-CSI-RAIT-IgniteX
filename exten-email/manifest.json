{
  "manifest_version": 3,
  "name": "PhishLens",
  "version": "1.1.0",
  "description": "AI-powered phishing detection for Gmail — runs entirely in-browser with ONNX Runtime Web and rule-based analysis. No backend, no API calls. Privacy-first.",
  "permissions": [
    "activeTab"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "lib/ort.min.js",
        "lib/tokenizer.js",
        "content.js"
      ],
      "css": [
        "styles/phishlens.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "model/*",
        "lib/*.wasm",
        "lib/*.js"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    }
  ]
}